{
  "productName": "Dirlete",
  "version": "1.0.0",
  "identifier": "com.dirlete.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dirlete",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../dirlete.ico",
      "../../dirlete.png"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
